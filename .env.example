# Neon Postgres (required for all DB operations)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Local Redis for BullMQ (Milestone 2 ingestion worker)
REDIS_URL=redis://localhost:6379

# Embedding provider: "local" uses Transformers.js (bge-small-en-v1.5, no API key)
EMBEDDING_PROVIDER=local

# Demo org id — written automatically by `npm run db:seed`
DEMO_ORG_ID=
