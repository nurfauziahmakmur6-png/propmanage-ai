# Neon Postgres (required for all DB operations)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Local Redis for BullMQ (Milestone 2 ingestion worker)
REDIS_URL=redis://localhost:6379

# Embedding provider: "local" uses Transformers.js (bge-small-en-v1.5, no API key)
EMBEDDING_PROVIDER=local

# Reranker: "local" uses Transformers.js cross-encoder (ms-marco-MiniLM-L-6-v2, no API key)
RERANKER=local

# Answer LLM (Milestone 3). Default "groq" (free at console.groq.com). Retrieval and the
# eval run WITHOUT this; only /api/kb/query answer generation needs it.
LLM_PROVIDER=groq
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# Swap providers: set LLM_PROVIDER=openai|anthropic and the matching key/model.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Minimum reranker score (0-1) a chunk must clear or the KB refuses instead of guessing.
# RAG_RERANK_THRESHOLD=0.3

# Demo org id — written automatically by `npm run db:seed`
DEMO_ORG_ID=
